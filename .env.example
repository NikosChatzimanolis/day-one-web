# Resend — required for contact + review form emails
# Get from https://resend.com/api-keys or the Vercel Resend integration
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# From addresses are set in lib/email.ts (no env vars needed):
#   Contact form → contact@dayone-web.com
#   Review form  → feedback@dayone-web.com
# Both deliver to contact@dayone-web.com (forwarded via ImprovMX)
